# Feature 0045 — Phase 3 validation replay.
# Mirrors the shape of apps/replay/conf/replay_ltcusdt_phase4_v4.yaml but
# points at the 0045 snapshot DB and a separate output directory so v4
# baseline results are preserved for the before/after comparison in
# docs/features/0045_REVIEW.md.

database_url: "sqlite:///data/recorder_0045_snapshot.db"
run_id: "f5813cbf-3bc4-4c8b-b383-2b4f3e17427c"

symbol: "LTCUSDT"
# Ticker data starts at 2026-05-18T08:50:48Z; first fill at 09:10:12Z.
# Seed slightly after ticker start so the initial REST snapshot
# (exchange_ts=08:04:59) is already in scope for position seeding.
start_ts: "2026-05-18T08:55:00Z"
end_ts:   "2026-05-18T10:06:00Z"

strategy:
  tick_size: "0.1"
  grid_count: 20
  grid_step: 0.3
  amount: "x0.001"
  commission_rate: "0.0002"
  enable_risk_multipliers: true
  early_imbalance_multiplier: 1.0
  # 0045 — hedge-aware IM/MM helper inputs:
  taker_fee_rate: "0.00075"
  hedge_smaller_buffer_factor: "5.657"

seed:
  enabled: true
  at_ts: "2026-05-18T08:55:00Z"
  account_id: "00000000-0000-0000-0000-000000000002"
  strat_id: "ltcusdt_test"
  grid_state_path: "db/grid_anchor.phase4.json"
  wallet_coin: "USDT"

fill_simulator:
  mode: "book_touch"

initial_balance: "10000"

enable_funding: true
funding_rate: "0.0001"
wind_down_mode: "leave_open"

output_dir: "results/replay_0045_validation"
price_tolerance: 0
qty_tolerance: "0.001"
