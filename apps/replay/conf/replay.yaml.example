# Config auto-discovery search path (first match wins):
#   1. --config CLI arg
#   2. REPLAY_CONFIG_PATH env var
#   3. conf/replay.yaml
#   4. replay.yaml

database_url: "sqlite:///recorder.db"
# run_id: "..."  # Optional: auto-discovers latest recording run
symbol: "BTCUSDT"

# Optional time range overrides (defaults to run's start/end)
# start_ts: "2025-02-20T00:00:00"
# end_ts: "2025-02-23T00:00:00"

strategy:
  tick_size: 0.1
  grid_count: 50
  grid_step: 0.2
  amount: "x0.001"
  commission_rate: 0.0002
  # Risk-mgmt tunables (feature 0071, issue #162). When omitted they default
  # to BacktestStrategyConfig values (0.8 / 1.2 / 0.15 / false / 10) — NOT
  # your live gridbot values. Populate ALL five to mirror live risk-mgmt;
  # a partial set silently mixes live and backtest-default semantics.
  # Live-mirror examples below are operator-supplied, NOT repo-derived —
  # confirm against your own live config before use (the repo's only gridbot
  # config, gridbot.yaml.example, ships 0.15 / false as the verified baseline).
  # To verify, read the gitignored live config on the bot host (per-strategy
  # values live under each strategies[] entry):
  #   grep -nE "min_liq_ratio|max_liq_ratio|min_total_margin|increase_same_position_on_low_margin|leverage" apps/gridbot/conf/gridbot.yaml
  # min_liq_ratio: 0.8
  # max_liq_ratio: 1.2
  # min_total_margin: 3      # LTC example — operator-supplied, confirm against your live config (SOL example: 2.5)
  # increase_same_position_on_low_margin: true  # live example — operator-supplied; true = boost own side x2 on low margin; false = suppress opposite side x0.5
  # leverage: 10

# Optional fill simulator mode:
#   book_touch (default, uses recorded L1 bid/ask for parity with live exchange),
#   trade_through_at_limit, or strict_cross (conservative, trade-tape only).
#   Override to strict_cross to reproduce pre-0033 baseline.
# fill_simulator:
#   mode: book_touch

initial_balance: 10000
enable_funding: true
funding_rate: 0.0001
wind_down_mode: "leave_open"

output_dir: "results/replay"
price_tolerance: 0
qty_tolerance: 0.001

# Optional seed-from-recorder mode (feature 0029). When enabled, replay
# reconstructs live state at `at_ts` (positions, wallet, grid, orders).
# seed:
#   enabled: true
#   at_ts: "2026-06-01T17:42:10Z"
#   account_id: "<uuid from grid_db.identity>"
#   strat_id: "solusdt_test"
#   wallet_coin: "USDT"
#   # Feature 0065: re-mark non-USDT collateral so backtest totalEquity floats
#   # like live. List every non-USDT coin held as collateral over the window.
#   # PAIRED CONFIG (both required): every coin here must ALSO have its *USDT
#   # symbol in the recorder's `collateral_symbols` (see recorder.yaml.example)
#   # for the recording window — otherwise ticker_snapshots has no marks and
#   # the coin runs on the seed mark all window (logged WARNING).
#   collateral_coins: ["SOL"]
#   collateral_symbol_map: {"SOL": "SOLUSDT"}   # optional; default {coin}USDT
#   # optional — NOT applied to total_equity in 0065 (future margin parity only)
#   # collateral_value_ratios: {"SOL": "0.85"}
#   # max wallet-row age for using usdValue as seed mark; else ticker at at_ts
#   # collateral_wallet_max_staleness: 60
