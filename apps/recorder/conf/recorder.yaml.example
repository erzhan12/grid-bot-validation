# Data Recorder Configuration Example
# Copy to recorder.yaml and update with your settings

symbols:
  - "BTCUSDT"

# Feature 0065: extra *USDT perp symbols to subscribe ticker for, so non-USDT
# collateral coins (e.g. SOL held as UTA margin collateral) have marks in
# ticker_snapshots for replay totalEquity re-marking. De-duplicated with
# `symbols`; NOT subscribed for executions/positions/orders. List every coin
# ever held as collateral over the recording window.
# collateral_symbols:
#   - "SOLUSDT"

# Database (SQLite file path)
database_url: "sqlite:///recorder.db"

# Use mainnet by default (set to true for testnet)
testnet: false

# Set to true if needed for debugging or analysis;
# significantly increases storage (~85% of total).
capture_public_trades: false

# Writer settings
batch_size: 100
flush_interval: 5.0

# Gap reconciliation threshold (seconds)
gap_threshold_seconds: 5.0

# Health log interval (seconds)
health_log_interval: 300  # log health every 5 minutes

# Optional: uncomment to also capture private streams
# IMPORTANT: chmod 600 recorder.yaml to protect credentials on shared hosts
# account:
#   # Must match gridbot accounts[].name — drives uuid5 identity
#   # (grid_db.identity.account_id_for / user_id_for) so recorder and
#   # gridbot share the same User/BybitAccount rows.
#   name: "YOUR_ACCOUNT_NAME"
#   # Must match gridbot strategies[].strat_id for this account — drives
#   # strategy_id_for so recorder Runs FK to gridbot's Strategy row.
#   strat_id: "YOUR_STRAT_ID"
#   api_key: "YOUR_API_KEY"
#   api_secret: "YOUR_API_SECRET"
