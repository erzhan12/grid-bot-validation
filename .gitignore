Thumbs.db

# Config files with secrets
apps/*/config/production.yaml
apps/*/config/secrets.yaml

# Config files with credentials
apps/pnl_checker/conf/pnl_checker.yaml
apps/recorder/conf/recorder.yaml
apps/replay/conf/replay.yaml
apps/gridbot/conf/gridbot.yaml

# Per-recording replay configs (run_id/timestamps change every recorder run).
# Canonical template lives at apps/replay/conf/replay_ltcusdt_phase4.yaml.example.
apps/replay/conf/replay_*.yaml
# Per-window iterative replay configs (e.g. iterative_v9.yaml,
# iterative_v10_ltc.yaml) — each run targets a specific recorded window
# with its own run_id and timestamps; not meant for the repo.
apps/replay/conf/iterative_*.yaml

# Recorded data
data/

# Generated output
output/
results/
apps/pnl_checker/src/pnl_checker/output/

# Runtime caches
conf/instruments_cache.json
conf/risk_limits_cache.json
/keys.yaml

# Incident captures: full per-incident bundles (raw .jsonl 0.9–36 MB, .gz
# archives, .summary.md post-mortems) live on disk but are kept out of the repo.
docs/incidents/
